# swap-api environment — copy to .env on the server and fill in.
# .env is gitignored; never commit it. `docker compose up -d --build` reads this file.

# ── Reverse proxy + TLS (read by nginx-proxy / acme-companion) ──────────────
# Public hostname this API answers on; nginx-proxy routes it to the container.
VIRTUAL_HOST=api.example.com
# Host acme-companion requests/renews a Let's Encrypt cert for (usually == VIRTUAL_HOST).
LETSENCRYPT_HOST=api.example.com
# Contact address Let's Encrypt uses for expiry notices.
LETSENCRYPT_EMAIL=you@example.com

# ── Voi network endpoints ───────────────────────────────────────────────────
# Defaults shown are the code's fallbacks; override for a private node.
ALGOD_URL=https://mainnet-api.voi.nodely.dev
ALGOD_TOKEN=
ALGOD_PORT=
INDEXER_URL=https://mainnet-idx.voi.nodely.dev
INDEXER_TOKEN=
INDEXER_PORT=

# ── Supabase request logging (optional) ─────────────────────────────────────
# Set SUPABASE_ENABLED=true and provide URL + KEY to log quote/unwrap requests.
SUPABASE_ENABLED=false
SUPABASE_URL=
SUPABASE_KEY=

# ── Pool discovery lifecycle (see DEPLOY.md "Boot latency") ─────────────────
# How many pools to discover concurrently on cold start (Mimir + algod round-trips
# per pool). Must be a positive integer; hard-clamped to 10 regardless of this
# value, so misconfiguration can't recreate an unbounded burst. Defaults shown
# are the code's fallbacks.
DISCOVERY_CONCURRENCY=6
# Minimum fraction (0-1] of configured pools that must discover successfully for
# boot to proceed; below this, initialization fails loudly instead of serving a
# silently-partial pool set.
DISCOVERY_MIN_SUCCESS_RATIO=0.7
# How often (ms) a pool that failed discovery is retried; checked lazily on each
# request rather than a timer.
DISCOVERY_RETRY_TTL_MS=120000
# Max age (ms) of the on-disk warm-restart discovery cache before it's ignored
# and discovery reruns from scratch, even if it's otherwise a complete snapshot.
DISCOVERY_CACHE_MAX_AGE_MS=86400000

# ── Platform fee (optional) ─────────────────────────────────────────────────
# Address that collects the multi-pool split gain, and the fee in basis points.
# PLATFORM_FEE_BPS must be an integer in [0, 10000] (10000 = 100% of the gain,
# the ceiling). Unset/empty = no fee; any value > 10000 is rejected when the fee
# config is read (fails the quote with a clear error), never silently clamped.
PLATFORM_FEE_ADDR=
PLATFORM_FEE_BPS=

# ── Abuse controls: fan-out cap, rate limiting, CORS (TASK-26) ──────────────
# Max concrete pool combinations evaluated PER /quote REQUEST (a budget shared
# across every candidate route inside findOptimalMultiHopRoute) — the primary
# lever against one request fanning out into many upstream pool fetches. Must
# be an integer in [1, 1000]; any other value (unset, non-numeric, 0,
# negative, fractional, or absurdly large like 1e100) falls back to 10. Lower
# = fewer candidates evaluated, which can select a very slightly worse
# route/split; 10 is a deliberate default (diminishing returns beyond it),
# tunable up to the 1000 ceiling without a deploy if a legitimate route needs
# more.
MAX_ROUTE_COMBINATIONS=10
# Best-effort per-IP rate limiting (express-rate-limit) on /quote and /unwrap.
# BEST-EFFORT ONLY on serverless: uses an in-memory, per-instance store, not
# shared across Vercel's cold-started instances. WINDOW_MS must be an integer
# in [1, 2147483647] (Node's max timer delay); MAX must be a positive safe
# integer. Invalid/out-of-range values fall back to these defaults.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
# Comma-separated CORS allowlist. Unset/empty OR an explicit '*' = wide-open
# (Access-Control-Allow-Origin: *), preserving the historical default for this
# public, unauthenticated API. Set to lock CORS down to specific origins
# without a code change, e.g.
# CORS_ORIGINS=https://app.example.com,https://foo.example.com
CORS_ORIGINS=

# ── Misc ────────────────────────────────────────────────────────────────────
# Verbose debug logging — leave empty in production.
DEBUG=
# NOTE: PORT is fixed to 3000 by docker-compose. Do NOT set VERCEL here — the app only
# starts its own HTTP listener when VERCEL is unset, which is exactly what we want in Docker.
